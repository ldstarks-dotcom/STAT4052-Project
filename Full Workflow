#Random Forest
library(randomForest)
#check for missing values
sum(is.na(df))
modelrf = randomForest(quality ~ . , data = traindf, ntree = 500, mtry = 3, importance = TRUE)
modelrf 
#finding best mtry by minimizing OOB 
tuned = tuneRF(
  x        = traindf[, -which(names(traindf) == "quality")],  # predictors
  y        = traindf$quality,                                # target
  mtryStart  = floor(sqrt(11)),  # starting value
  stepFactor = 1.5,             # multiply/divide mtry by this at each step
  improve    = 0.01,            # min relative improvement to continue
  ntreeTry   = 300,             # trees per candidate mtry
  plot       = TRUE             # plots OOB error vs mtry
)
best_mtry = tuned[which.min(tuned[, 2]), 1]
preds = predict(modelrf, newdata = testdf)
actuals = testdf$quality
mae = mean(abs(preds - actuals))
rmse = sqrt(mean((preds- actuals)^2))
r= cor(preds, actuals)
r2 = r^2
cat("MAE:", mae, "|nRMSE:", rmse, "\nR^2:", r2)

